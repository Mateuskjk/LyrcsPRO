<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:LyricsPro.Converters"
             x:Class="LyricsPro.Views.PresenterControlView">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

    <!-- Header bar -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <Ellipse Width="10" Height="10" Fill="#D4610A" />
        <TextBlock Text="AO VIVO" FontSize="11" FontWeight="Bold"
                   Foreground="#D4610A" VerticalAlignment="Center" />
        <TextBlock Text="{ReflectionBinding ProgressText}" FontSize="13"
                   Foreground="#888" VerticalAlignment="Center" />
      </StackPanel>

      <!-- Font size -->
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                  VerticalAlignment="Center" Margin="0,0,12,0">
        <Button Classes="NavBtn" Width="30" Height="30" CornerRadius="6"
                Command="{ReflectionBinding DecreaseFontCommand}"
                ToolTip.Tip="Diminuir fonte (-)">
          <TextBlock Text="A" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
        <TextBlock Text="{ReflectionBinding FontSize, StringFormat='{}{0:0}pt'}"
                   FontSize="12" Foreground="#888" VerticalAlignment="Center"
                   Width="38" TextAlignment="Center" />
        <Button Classes="NavBtn" Width="30" Height="30" CornerRadius="6"
                Command="{ReflectionBinding IncreaseFontCommand}"
                ToolTip.Tip="Aumentar fonte (+)">
          <TextBlock Text="A" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Button>
      </StackPanel>

      <!-- Blank toggle -->
      <Button Grid.Column="2"
              Command="{ReflectionBinding ToggleBlankCommand}"
              Background="{ReflectionBinding IsBlank, Converter={x:Static conv:BoolToBrushConverter.BlankInstance}}"
              Foreground="White" FontWeight="SemiBold"
              Padding="14,8" CornerRadius="8" Margin="0,0,8,0"
              ToolTip.Tip="B — Tela preta no projetor">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"
                    Width="14" Height="14" />
          <TextBlock Text="{ReflectionBinding IsBlank, Converter={x:Static conv:BoolToStringConverter.BlankInstance}}"
                     FontSize="12" />
        </StackPanel>
      </Button>

      <!-- Reopen projector (shown when window is closed but slides loaded) -->
      <Button Grid.Column="3"
              IsVisible="{ReflectionBinding !IsActive}"
              Command="{ReflectionBinding ReopenProjectorCommand}"
              Background="#D4610A" Foreground="White"
              FontWeight="SemiBold" Padding="12,8" CornerRadius="8"
              ToolTip.Tip="Reabrir janela do projetor">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="M8 5v14l11-7z" Width="13" Height="13" />
          <TextBlock Text="Reabrir" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

      <!-- Close projector window (keep slides) -->
      <Button Grid.Column="3" Classes="NavBtn" Width="36" Height="36" CornerRadius="8"
              IsVisible="{ReflectionBinding IsActive}"
              Command="{ReflectionBinding CloseProjectorCommand}"
              ToolTip.Tip="Fechar janela do projetor (slides mantidos)">
        <PathIcon Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                  Width="14" Height="14" Foreground="#888" />
      </Button>
    </Grid>

    <!-- Remote control panel -->
    <Border Grid.Row="1"
            Margin="0,0,0,10"
            Background="#0D0D0A"
            BorderBrush="#2A1800" BorderThickness="1"
            CornerRadius="10" Padding="12,10"
            IsVisible="{ReflectionBinding RemoteActive}">
      <StackPanel Spacing="10">

        <!-- URL info -->
        <Grid ColumnDefinitions="Auto,*">
          <PathIcon Grid.Column="0" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.86-7-7.93s3.06-7.44 7-7.93v15.86zm2 0V4.07c3.94.49 7 3.86 7 7.93s-3.06 7.44-7 7.93z"
                    Width="16" Height="16" Foreground="#D4610A" Margin="0,0,8,0" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1">
            <TextBlock Text="Controle pelo Celular (mesmo WiFi)"
                       FontSize="12" FontWeight="Bold" Foreground="#F0F0F0" />
            <TextBlock Text="{ReflectionBinding RemoteUrl}"
                       FontSize="11" Foreground="#D4610A" />
          </StackPanel>
        </Grid>

        <!-- 3 QR codes -->
        <Grid ColumnDefinitions="*,8,*,8,*">

          <!-- Controle -->
          <StackPanel Grid.Column="0" Spacing="4" HorizontalAlignment="Center">
            <Border Width="76" Height="76" CornerRadius="8"
                    Background="#111" ClipToBounds="True">
              <Image Source="{ReflectionBinding RemoteUrl, Converter={x:Static conv:UrlToQrConverter.Instance}}"
                     Stretch="Uniform" />
            </Border>
            <TextBlock Text="Controle" FontSize="10" Foreground="#666"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <!-- Letras -->
          <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Center">
            <Border Width="76" Height="76" CornerRadius="8"
                    Background="#111" ClipToBounds="True">
              <Image Source="{ReflectionBinding RemoteUrlLyrics, Converter={x:Static conv:UrlToQrConverter.Instance}}"
                     Stretch="Uniform" />
            </Border>
            <TextBlock Text="Letras" FontSize="10" Foreground="#666"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <!-- Bíblia -->
          <StackPanel Grid.Column="4" Spacing="4" HorizontalAlignment="Center">
            <Border Width="76" Height="76" CornerRadius="8"
                    Background="#111" ClipToBounds="True">
              <Image Source="{ReflectionBinding RemoteUrlBible, Converter={x:Static conv:UrlToQrConverter.Instance}}"
                     Stretch="Uniform" />
            </Border>
            <TextBlock Text="Bíblia" FontSize="10" Foreground="#666"
                       HorizontalAlignment="Center" />
          </StackPanel>

        </Grid>
      </StackPanel>
    </Border>

    <!-- Slide grid -->
    <ScrollViewer Grid.Row="2">
      <ItemsControl ItemsSource="{ReflectionBinding AllSlides}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Width="200" Height="110" Margin="0,0,10,10"
                    Background="Transparent" BorderThickness="0"
                    Padding="0" Cursor="Hand"
                    Classes="ThumbCard"
                    Command="{ReflectionBinding $parent[UserControl].DataContext.GoToSlideCommand}"
                    CommandParameter="{ReflectionBinding Index}">
              <Border CornerRadius="10" ClipToBounds="True"
                      BorderBrush="#2A2A2A" BorderThickness="1">
                <Panel>
                  <Border>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#0A0A0A" Offset="0" />
                        <GradientStop Color="#1A0A00" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>

                  <Image Source="{ReflectionBinding BackgroundImagePath, Converter={x:Static conv:PathToImageConverter.Instance}}"
                         Stretch="UniformToFill" Opacity="0.4" />

                  <TextBlock Text="{ReflectionBinding Text}"
                             FontSize="11" Foreground="White"
                             TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                             LineHeight="16" MaxLines="4"
                             Margin="10,8" VerticalAlignment="Center"
                             TextAlignment="Center" />

                  <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                          Margin="0,5,5,0" Padding="5,2"
                          Background="#CC000000" CornerRadius="4">
                    <TextBlock Text="{ReflectionBinding Index}"
                               FontSize="9" Foreground="#D4610A" />
                  </Border>
                </Panel>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Navigation bar -->
    <Border Grid.Row="3" Background="#0D0D0D"
            BorderBrush="#1E1E1E" BorderThickness="0,1,0,0"
            Padding="16,10">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,*,Auto" MinHeight="56">

        <!-- Encerrar -->
        <Button Grid.Column="0"
                Command="{ReflectionBinding ClearCommand}"
                Background="#1A0808" Foreground="#C0392B"
                Padding="16,0" CornerRadius="10" Height="46"
                ToolTip.Tip="Encerrar apresentação (limpa slides)">
          <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                    Width="15" Height="15" />
        </Button>

        <!-- Anterior -->
        <Button Grid.Column="2"
                Command="{ReflectionBinding PreviousCommand}"
                Background="#1E1E1E" Foreground="#F0F0F0"
                Padding="22,0" CornerRadius="10" Height="46" Margin="0,0,8,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <PathIcon Data="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z" Width="16" Height="16" />
            <TextBlock Text="Anterior" FontSize="14" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Tela Preta -->
        <Button Grid.Column="3"
                Command="{ReflectionBinding ToggleBlankCommand}"
                Background="{ReflectionBinding IsBlank, Converter={x:Static conv:BoolToBrushConverter.BlankInstance}}"
                Foreground="White" FontWeight="SemiBold"
                Padding="24,0" CornerRadius="10" Height="46">
          <TextBlock Text="B — Tela Preta" FontSize="14" />
        </Button>

        <!-- Próximo -->
        <Button Grid.Column="4"
                Command="{ReflectionBinding NextCommand}"
                Background="#1E1E1E" Foreground="#F0F0F0"
                Padding="22,0" CornerRadius="10" Height="46" Margin="8,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Próximo" FontSize="14" VerticalAlignment="Center" />
            <PathIcon Data="M10 6 8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" Width="16" Height="16" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

  </Grid>
</UserControl>
